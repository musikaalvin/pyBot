# pyBot Environment Variables
# Copy this file to .env and fill in your values

# WhatsApp Session
# Get this by running the bot with an empty sessionID and scanning the QR code
SESSION_ID=

# Owner Information (can be multiple)
OWNER_NUMBERS=256748675846
OWNER_NAMES=pyLord

# Bot Configuration
BOT_NAME=pyBot
BOT_DESCRIPTION=Advanced WhatsApp Bot by pyLord
PREFIX=.

# Bot Features (set to 'true' to enable)
AUTO_READ=true
AUTO_TYPING=false
AUTO_BIO=false
AUTO_STICKER=false
AUTO_REACT=false
AUTO_DOWNLOAD=false
AUTO_VIEW_STATUS=false
AUTO_REACT_STATUS=false
AUTO_SAVE_STATUS=false
AUTO_RECORDING=false

# 🔥 Hackish/Cool Features
GHOST_MODE=false      # View messages without triggering blue ticks
SPY_MODE=false        # Forward all messages to owner secretly
FAKE_ONLINE=false     # Appear online even when offline
STEALTH_STATUS=false  # View status updates without sender knowing

# API Keys (get these from respective services)
OPENAI_API_KEY=
DEEPAI_API_KEY=
REMOVE_BG_API_KEY=

# Update Configuration
UPDATE_ZIP_URL=https://github.com/musikaalvin/pyBot/archive/refs/heads/main.zip

# Social Media Links (optional)
YOUTUBE_URL=http://youtube.com/@pyLord2003
INSTAGRAM_URL=https://instagram.com/pylord
GITHUB_URL=https://github.com/musikaalvin/pyBot